list(APPEND CMAKE_MODULE_PATH "@PROJECT_SOURCE_DIR@/cmake")

if(NOT TARGET libmim OR NOT TARGET mim)
    message(FATAL_ERROR "The build-tree mim package requires the in-tree MimIR targets")
endif()

if(NOT TARGET mim::libmim)
    add_library(mim::libmim ALIAS libmim)
endif()
if(NOT TARGET mim::mim)
    add_executable(mim::mim ALIAS mim)
endif()

set(MIM_PLUGIN_LIST "" CACHE INTERNAL "MIM_PLUGIN_LIST" FORCE)
set(MIM_PLUGIN_LAYOUT "" CACHE INTERNAL "MIM_PLUGIN_LAYOUT" FORCE)
set(MIM_TARGET_NAMESPACE "mim::")

if(NOT COMMAND add_mim_plugin)
    include(Mim)
endif()
