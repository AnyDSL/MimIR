import sflow;

fun extern foo () = %sflow.switch @3 foo exit default ((0, case0), (1, case1), (2, case2)) 1 () where
  con case2 (_, _) = exit 2;
  con case1 (_, _) = exit 1;
  con case0 (_, struct: %sflow.Struct foo default exit) = %sflow.exit.break struct 0;
  con default (_, _) = exit 4;
  con exit (x: Nat) = return x;
end;
