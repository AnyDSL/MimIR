plugin core;
plugin eqsat;

lam extern _rulesets(): %eqsat.Ruleset =
    %eqsat.rulesets (
        %eqsat.core,
        %eqsat.math,
    );

fun extern f(a: I8): «4; I8» =
    return (%core.wrap.sub 0               (a, 1I8),
            %core.wrap.sub %core.mode.nsw  (a, 1I8),
            %core.wrap.sub %core.mode.nuw  (a, 1I8),
            %core.wrap.sub %core.mode.nusw (a, 1I8));
