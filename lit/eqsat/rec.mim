plugin core;
plugin eqsat;

lam extern _rulesets(): %eqsat.Ruleset =
    %eqsat.rulesets (
        %eqsat.core,
        %eqsat.math,
    );

// TODO: is_even and is_odd are intern and thus not emitted by the sexpr emitter
lam is_even(i: Nat): Bool = (is_odd (%core.nat.sub (i, 1)), tt)#(%core.ncmp.e (i, 0))
and
lam is_odd (i: Nat): Bool = (is_even(%core.nat.sub (i, 1)), ff)#(%core.ncmp.e (i, 0));

fun extern f(): Bool = return (is_even 4);
