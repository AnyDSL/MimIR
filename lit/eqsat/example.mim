// TODO: "phi" doesn't exist as variable of "nx" anymore so "ins(phi, i, 23I32)" fails
// - maybe some problem with how i am emitting the vars in lambda headers?
fun extern test(cond: Bool, a: «3; I32», b: «3; I32», i: Idx 3): «3; I32» =
    con nx(phi: «3; I32») = return ins(phi, i, 23I32);
    (cn () = nx a, cn () = nx b)#cond ();
