plugin core;
plugin eqsat;

fun extern _rulesets(): %eqsat.Ruleset =
    return (%eqsat.rulesets (
        %eqsat.core,
        %eqsat.math,
    ));

con extern and_lit [return : Cn Bool] =
    return
    (%core.bit2.and_ 0
        (%core.bit2.and_ 0
            (%core.bit2.and_ 0 (tt, tt),
             %core.bit2.and_ 0 (ff, ff)),
         %core.bit2.and_ 0
            (%core.bit2.and_ 0 (ff, tt),
             %core.bit2.and_ 0 (tt, ff))));
