plugin core;
plugin eqsat;

lam extern _rulesets(): %eqsat.Ruleset =
    %eqsat.rulesets (
        %eqsat.core,
    );

con extern and_lit [return : Cn Bool] =
    return
    (%core.bit2.and_ 0
        (%core.bit2.and_ 0
            (%core.bit2.and_ 0 (tt, tt),
             %core.bit2.and_ 0 (ff, ff)),
         %core.bit2.and_ 0
            (%core.bit2.and_ 0 (ff, tt),
             %core.bit2.and_ 0 (tt, ff))));

