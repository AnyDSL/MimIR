import core;

lam add (a: Nat) (b: Nat) = %core.nat.add (a, b);
lam le (a: Nat) (b: Nat) = %core.ncmp.le (a, b);

fun extern f (n: Nat): Nat =
    con hi (i: Nat) =
        con bi () = hj i;
        con xi () = return i;
        (xi, bi)#(le i n) ()
    and
    con hj (j: Nat) =
        let j_ = add j 1;
        con bj () = hj j_;
        con xj () = hi j_;
        (xj, bj)#(le j n) ();
    hi 0;
