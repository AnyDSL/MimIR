import core;

lam add (a: Nat) (b: Nat) = %core.nat.add (a, b);
lam le (a: Nat) (b: Nat) = %core.ncmp.le (a, b);

fun extern f (n: Nat): Nat =
    con hi (i: Nat) =
        con hj (j: Nat) =
            let j2 = add j 1;
            con bj () = hj j2;
            con xj () = hi (add i j);
            (xj, bj)#(le j n) ();
        con bi () = hj i;
        con xi () = return i;
        (xi, bi)#(le i n) ();
    hi 0;
