// RUN: rm -f %t.ll
// RUN: %mim %s --output-ll %t.ll
// RUN: FileCheck %s < %t.ll

plugin aie2p;
import core;
import compile;
import opt;
import aie2p;

con extern srs_test(acc: «32; I64», shift: I32, round: I32,
                   return: Cn [«32; I16»]) =
    let result = %aie2p.srs_i16_32 (acc, shift, round);
    return (result);

// CHECK: call {{.*}} @llvm.aie2p.I512.v32.acc64.srs(
