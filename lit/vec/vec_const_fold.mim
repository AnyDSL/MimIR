// RUN: %mim %s --output-ll - | FileCheck %s


plugin core;
plugin vec;
fun foo{n:Nat} (A: «n; Nat», B:«n; Nat»):  «n; Nat» = 
    let C = %vec.zip %core.nat.add (A, B);
    let D = %vec.zip %core.nat.sub (C, ‹n; 1›);
    return D;
fun extern bar(): «4; Nat» =
    let A = (1, 2, 3, 4);
    let B = (1, 2, 3, 4);
    ret C = foo @4 $ (A, B);
    ret D = foo @4 $ (A, B);
    return D;


// CHECK: define{{.*}} @bar
// CHECK: ret <4 x i64> <i64 1, i64 3, i64 5, i64 7>
